{
  "name": "guiders-pixel",
  "version": "1.6.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:visual:update": "playwright test visual-regression --update-snapshots",
    "test:unit": "jest --config jest.config.ts",
    "build": "webpack --mode=production",
    "start": "bash -c './wp-docker.sh start & webpack serve --mode=development'",
    "release:wp": "bash wordpress-plugin/build-plugin.sh",
    "release:wp:skip": "bash wordpress-plugin/build-plugin.sh --skip-build",
    "release:wp:publish": "bash wordpress-plugin/release-wp-publish.sh"
  },
  "keywords": [
    "chat",
    "real-time",
    "commercial",
    "visitor",
    "tracking",
    "pixel",
    "v2",
    "websocket"
  ],
  "author": "",
  "license": "ISC",
  "description": "Guiders SDK v2.0 - SDK optimizado para chat comercial en tiempo real con soporte para API v2",
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/clientjs": "^0.2.2",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv-webpack": "^8.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.55.0",
    "terser-webpack-plugin": "^5.3.10",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "clientjs": "^0.2.1",
    "preact": "^10.29.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^10.0.0"
  }
}
